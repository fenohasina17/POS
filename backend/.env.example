APP_NAME=DevOpsProject
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://app.local

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Connexion PostgreSQL (Utilisée par Kubernetes et Docker Compose)
DB_CONNECTION=pgsql
DB_HOST=postgres-svc
DB_PORT=5432
DB_DATABASE=appdb
DB_USERNAME=appuser
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120