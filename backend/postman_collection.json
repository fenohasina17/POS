{
  "info": {
    "name": "POS-B API",
    "_postman_id": "pos-b-collection",
    "description": "Collection Postman de l'API POS-B (exemples)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"secret\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api","login"] }
          }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/register", "host": ["{{baseUrl}}"], "path": ["api","register"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/api/me", "host": ["{{baseUrl}}"], "path": ["api","me"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "List Products", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api","products"] } } }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Create Pending Order",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"table_id\": 1,\n  \"user_id\": 1,\n  \"point_of_sale_id\": 1,\n  \"cash_register_session_id\": 1,\n  \"order_lines\": [ { \"product_id\": 1, \"quantity\": 2, \"price\": 500 } ]\n}" },
            "url": { "raw": "{{baseUrl}}/api/sales/pending-order", "host": ["{{baseUrl}}"], "path": ["api","sales","pending-order"] }
          }
        },
        {
          "name": "Validate Order (example)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": { "mode": "raw", "raw": "{\n  \"payment_id\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/api/sales/1/validate", "host": ["{{baseUrl}}"], "path": ["api","sales","1","validate"] }
          }
        }
      ]
    },
    {
      "name": "Printers",
      "item": [
        { "name": "Scan Printers", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/printer-scan", "host": ["{{baseUrl}}"], "path": ["api","printer-scan"] } } },
        { "name": "List Printers", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "url": { "raw": "{{baseUrl}}/api/printers", "host": ["{{baseUrl}}"], "path": ["api","printers"] } } }
      ]
    }
  ]
}
