# Application
APP_NAME=POS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://SERVER_IP:8443
SERVER_IP=SERVER_IP

# Frontend
FRONTEND_URL=https://SERVER_IP:5443
SANCTUM_STATEFUL_DOMAINS=SERVER_IP:5443,localhost:5443

# Frontend build (URL absolue de l'API utilisée par Vite au build)
VITE_API_URL=https://SERVER_IP:8443

# Database
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=pos_system
DB_USERNAME=
DB_PASSWORD=

# Cache
CACHE_STORE=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=sync

# Logging — 'daily' = 1 fichier par jour, conserve 14 jours
LOG_CHANNEL=daily
LOG_LEVEL=error
LOG_DEPRECATIONS_CHANNEL=null
